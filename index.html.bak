      "YouTube SEO", "AEO", "Schema Markup", "Prompt Engineering"
    ]
  }
  </script>

  <!-- AEO / SEO JSON-LD Schema (FAQ) for AI Overviews -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [{
      "@type": "Question",
      "name": "How does Anshuman use AI in digital marketing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Anshuman integrates AI for prompt-engineered copywriting, automated bidding strategies, predictive campaign analysis, and structuring web content for Answer Engine Optimization (AEO)."
      }
    }, {
      "@type": "Question",
      "name": "What is an AEO Content Engine?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "An AEO (Answer Engine Optimization) Content Engine is a framework that structures data using extensive JSON-LD schema, high semantic density, and direct answers to ensure brands appear in AI tools like Perplexity, ChatGPT, and Google AI Overviews."
      }
    }]
  }
  </script>
  
