  <!-- JS for Foundation interactions -->
  <script>
    // 1. Loading Screen
    window.addEventListener('load', () => {
      // Start progress bar
      setTimeout(() => { document.getElementById('loader-bar').style.width = '100%'; }, 100);
      
      // Cycle text
      const sub = document.getElementById('loader-subtext');
      const msgs = ["Connecting to AI Stack...", "Analyzing Campaigns...", "Portfolio Ready."];
      let i = 0;
      const tInt = setInterval(() => {
        if(i < msgs.length) { sub.innerText = msgs[i]; i++; }
        else clearInterval(tInt);
      }, 600);

      // Hide loader
      setTimeout(() => {
        const loader = document.getElementById('loader');
        loader.style.opacity = '0';
        setTimeout(() => { loader.style.display = 'none'; }, 500);
      }, 2200);
    });

    // 2. Custom Cursor
    const cur = document.getElementById('cur');
    const cur2 = document.getElementById('cur2');
    
    // Check if device supports hover (disables custom cursor on touch devices)
    const isTouchDevice = (('ontouchstart' in window) || (navigator.maxTouchPoints > 0) || (navigator.msMaxTouchPoints > 0));
    
    if(!isTouchDevice) {
      document.addEventListener('mousemove', e => {
        cur.style.left = e.clientX + 'px';
        cur.style.top = e.clientY + 'px';
        
        // Slight lag for outer ring
        setTimeout(() => {
          cur2.style.left = e.clientX + 'px';
          cur2.style.top = e.clientY + 'px';
        }, 80);
      });
      
      // Interactive elements class toggling
      const interactives = document.querySelectorAll('a, button');
      interactives.forEach(el => {
        el.addEventListener('mouseenter', () => cur2.classList.add('big'));
        el.addEventListener('mouseleave', () => cur2.classList.remove('big'));
      });
    } else {
      cur.style.display = 'none';
      cur2.style.display = 'none';
    }

    // 3. Navigation Scrolled State
    const nav = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if(window.scrollY > 60) nav.classList.add('sc');
      else nav.classList.remove('sc');
    });

    // 4. Mobile Menu Toggle
    const hamBtn = document.getElementById('ham-btn');
    const mobMenu = document.getElementById('mob-menu');
    const mobLinks = document.querySelectorAll('.mob-link');
    
    hamBtn.addEventListener('click', () => {
      mobMenu.classList.toggle('open');
      hamBtn.innerText = mobMenu.classList.contains('open') ? 'ÃƒÂ¢Ã…â€œÃ¢â‚¬Â¢' : 'ÃƒÂ¢Ã‹Å“Ã‚Â°';
    });
    
    mobLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobMenu.classList.remove('open');
        hamBtn.innerText = 'ÃƒÂ¢Ã‹Å“Ã‚Â°';
      });
    });

    // 5. Robot Interactions
    const robot = document.getElementById('robot-main');
    const speech = document.getElementById('robot-speech');
    const speechMsgs = [
      "I just optimized a Google Ads campaign! ÃƒÂ°Ã…Â¸Ã…Â½Ã‚Â¯",
      "AEO schema validated ÃƒÂ¢Ã…â€œÃ¢â‚¬Å“ Rich Results ready!",
      "Running YouTube SEO analysis... ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã‚Âº",
      "Building your growth engine ÃƒÂ¢Ã…Â¡Ã¢â€žÂ¢ÃƒÂ¯Ã‚Â¸Ã‚Â",
      "Data: increase budget on campaign 3 ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã…Â ",
      "5 AI-written ad headlines in 10 seconds ÃƒÂ¢Ã…Â¡Ã‚Â¡",
      "Full-funnel dashboard is live ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã‹â€ "
    ];
    let msgIndex = 0;
    let sTimer;

    // Click pop and cycle speech
    robot.addEventListener('click', () => {
      robot.classList.remove('pop');
      void robot.offsetWidth; // trigger reflow
      robot.classList.add('pop');
      
      // Update message
      msgIndex = (msgIndex + 1) % speechMsgs.length;
      speech.innerText = speechMsgs[msgIndex];
      
      // Show speech bubble
      clearTimeout(sTimer);
      speech.classList.add('show');
      sTimer = setTimeout(() => { speech.classList.remove('show'); }, 3200);
    });

    if(!isTouchDevice) {
      robot.addEventListener('mouseenter', () => cur2.classList.add('big'));
      robot.addEventListener('mouseleave', () => cur2.classList.remove('big'));
    }

    // Auto wave every 8s
    setInterval(() => {
      robot.classList.add('wave');
      setTimeout(() => { robot.classList.remove('wave'); }, 800);
    }, 8000);

    // 6. Magnetic Buttons Setup
    document.querySelectorAll('.btnp, .btno').forEach(btn => {
      // Ensure cursor grows on these buttons
      if(!isTouchDevice) {
        btn.addEventListener('mousemove', e => {
          const rect = btn.getBoundingClientRect();
          const x = e.clientX - rect.left - rect.width / 2;
          const y = e.clientY - rect.top - rect.height / 2;
          btn.style.transform = `translate(${x * 0.3}px, ${y * 0.3}px)`;
        });
        btn.addEventListener('mouseleave', () => {
          btn.style.transform = 'translate(0, 0)';
          btn.style.transition = 'transform 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275)';
        });
        btn.addEventListener('mouseenter', () => {
          btn.style.transition = 'transform 0.1s ease';
        });
      }
    });

    // 7. Scroll Reveals (IntersectionObserver)
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
    
    // Visibility fallback
    setTimeout(() => {
      document.querySelectorAll('.reveal').forEach(el => {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      });
    }, 3000);

    // 8. Stats Count-up
    const stats = document.querySelectorAll('.stat-num');
    let hasCounted = false;
    
    const statObserver = new IntersectionObserver((entries) => {
      if(entries[0].isIntersecting && !hasCounted) {
        hasCounted = true;
        stats.forEach(st => {
          const target = parseFloat(st.getAttribute('data-target'));
          const suffix = st.getAttribute('data-suffix');
          let n = 0;
          const step = target / 44;
          const tInt = setInterval(() => {
            n += step;
            if(n >= target) { n = target; clearInterval(tInt); }
            st.innerText = Math.floor(n) + suffix;
          }, 26);
        });
      }
    }, { threshold: 0.5 });
    
    if(document.querySelector('.stats-bar')) {
      statObserver.observe(document.querySelector('.stats-bar'));
    }

    // 9. Philosophy Slides
    function switchPhil(n) {
      document.querySelectorAll('.pbtn').forEach(b => b.classList.remove('on'));
      document.querySelectorAll('.phil-slide').forEach(s => s.classList.remove('on'));
      document.querySelectorAll('.pbtn')[n-1].classList.add('on');
      document.getElementById('ps-' + n).classList.add('on');
    }

    // 10. Experience Accordion
    function toggleExp(el) {
      const parent = el.parentElement;
      const wasOpen = parent.classList.contains('open');
      
      // Close all
      document.querySelectorAll('.exp-item').forEach(item => {
        item.classList.remove('open');
      });
      
      // Open clicked if it wasn't already open
      if(!wasOpen) {
        parent.classList.add('open');
      }
    }

    // 10.5 Project Expander
    function toggleProj(btn) {
      const card = btn.closest('.p-card');
      card.classList.toggle('open');
      if(card.classList.contains('open')) {
        btn.innerHTML = btn.innerHTML.replace('View ', 'Close ');
      } else {
        btn.innerHTML = btn.innerHTML.replace('Close ', 'View ');
      }
    }

    // 11. Bubble Arena Generation & Tooltips
    const bubblesData = [
      { emoji: 'ÃƒÂ°Ã…Â¸Ã…Â½Ã‚Â¯', label: 'Google Ads', color: '#FF6B2C', size: 82, p: 'Google', t: 'Search/PMax', l: 'Advanced', u: 'Lead Generation' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã‹Å“', label: 'Facebook Ads', color: '#1877F2', size: 74, p: 'Meta', t: 'Awareness', l: 'Intermediate', u: 'Brand + Sales' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã‚Â¸', label: 'Instagram', color: '#E1306C', size: 68, p: 'Meta', t: 'Reels/Stories', l: 'Intermediate', u: 'Engagement' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã‚Âº', label: 'YouTube SEO', color: '#FF0000', size: 78, p: 'YouTube', t: 'Organic', l: 'Advanced', u: 'Top-of-Funnel' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã¢â‚¬Å“Ã…Â ', label: 'Analytics', color: '#F4B400', size: 70, p: 'Google', t: 'GA4 + Looker', l: 'Advanced', u: 'KPI Reporting' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã‚Â¤Ã¢â‚¬â€œ', label: 'ChatGPT', color: '#10A37F', size: 76, p: 'OpenAI', t: 'Generation', l: 'Advanced', u: 'Content/Strategy' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã¢â‚¬ÂÃ‚Â', label: 'AEO/Schema', color: '#7B5EF8', size: 72, p: 'Web/Google', t: 'JSON-LD', l: 'Growing', u: 'AI Visibility' },
      { emoji: 'ÃƒÂ¢Ã…â€œÃ‚ÂÃƒÂ¯Ã‚Â¸Ã‚Â', label: 'Prompt Eng', color: '#10B981', size: 70, p: 'All AI', t: 'Structured', l: 'Advanced', u: '10x Speed' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã¢â‚¬â„¢Ã‚Â¬', label: 'Meta Ads', color: '#0082FB', size: 66, p: 'Meta', t: 'Advantage+', l: 'Intermediate', u: 'Conversions' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã…Â½Ã‚Â¨', label: 'Canva', color: '#00C4CC', size: 60, p: 'Canva', t: 'Design', l: 'Intermediate', u: 'Ad Creatives' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã¢â‚¬â„¢Ã‚Â¡', label: 'CRO', color: '#F59E0B', size: 64, p: 'Analytics', t: 'Optimization', l: 'Growing', u: 'CVR Uplift' },
      { emoji: 'ÃƒÂ°Ã…Â¸Ã…Â½Ã‚Â¬', label: 'CapCut', color: '#FF6B2C', size: 62, p: 'ByteDance', t: 'Video Edit', l: 'Intermediate', u: 'UGC Ads' }
    ];

    const arena = document.getElementById('arena');
    const bTip = document.getElementById('b-tip');
    
    if(arena) {
      bubblesData.forEach((b, i) => {
        const bub = document.createElement('div');
        bub.className = 'bub';
        bub.innerHTML = `<div style="display:flex; flex-direction:column; align-items:center; line-height:1;"><div style="font-size:32px;">${b.emoji}</div><div style="font-size:11px; font-family:var(--font-body); font-weight:700; color:var(--dark); margin-top:3px; letter-spacing:-0.2px;">${b.label}</div></div>`;
        
        // Randomize placement somewhat safely within boundaries
        const left = 10 + Math.random() * 70;
        const top = 10 + Math.random() * 70;
        const dur = (4 + Math.random() * 6).toFixed(1);
        const del = (Math.random() * 4).toFixed(1);
        
        bub.style.cssText = `
          width: ${b.size}px; height: ${b.size}px;
          background: ${b.color}12;
          border: 2px solid ${b.color}28;
          left: ${left}%; top: ${top}%;
          animation: antigrav ${dur}s infinite ${del}s ease-in-out;
        `;
        
        bub.addEventListener('mouseenter', (e) => {
          if(!isTouchDevice) cur2.classList.add('big');
          const rect = bub.getBoundingClientRect();
          
          document.getElementById('bt-title').innerText = `${b.emoji} ${b.label}`;
          document.getElementById('bt-title').style.color = b.color;
          document.getElementById('bt-plat').innerText = b.p;
          document.getElementById('bt-type').innerText = b.t;
          document.getElementById('bt-level').innerText = b.l;
          document.getElementById('bt-use').innerText = b.u;
          
          let popX = rect.left + b.size + 10;
          let popY = rect.top - 20;
          
          // boundary checks
          if(popX + 250 > window.innerWidth) popX = rect.left - 260;
          
          bTip.style.left = popX + 'px';
          bTip.style.top = popY + 'px';
          bTip.style.opacity = '1';
        });
        
        bub.addEventListener('mouseleave', () => {
          if(!isTouchDevice) cur2.classList.remove('big');
          bTip.style.opacity = '0';
        });
        
        arena.appendChild(bub);
      });
    }

  </script>
</body>
</html>







