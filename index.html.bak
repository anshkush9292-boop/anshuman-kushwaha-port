  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is AEO and why does it matter?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AEO (Answer Engine Optimization) structures content for AI search engines like Perplexity, ChatGPT, and Google AI Overviews using schema markup so brands appear as direct answers."
        }
      },
      {
        "@type": "Question",
        "name": "How does Anshuman use AI in marketing campaigns?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "He uses AI for prompt-engineered ad copy, automated bidding via Google PMax and Meta Advantage+, and Looker Studio dashboards for real-time decision making."
        }
      },
      {
        "@type": "Question",
        "name": "What results has Anshuman achieved?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "4-6% CTR on Google Ads, 800+ projected YouTube views with 7%+ CTR, Ã¢â€šÂ¹50K multi-channel campaign with 15% CVR uplift, and validated AEO schema achieving Google Rich Results eligibility."
        }
      },
      {
        "@type": "Question",
        "name": "How can I hire Anshuman Kushwaha?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Email anshkush9292@gmail.com or connect on LinkedIn at linkedin.com/in/anshuman-kushwaha-31bb95237"
        }
      },
      {
        "@type": "Question",
        "name": "What makes Anshuman different from other digital marketers?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "He combines full-funnel performance marketing with AI automation and AEO content strategy Ã¢â‚¬â€ building compounding growth systems rather than running isolated campaigns."
        }
      }
    ]
  }
  </script>

  <style>
    /* ==================================
       1. DESIGN SYSTEM & VARIABLES
       ================================== */
    :root {
      --primary: #FF6B2C;
      --dark: #1A1A1A;
      --bg-white: #FFFFFF;
      --bg-light: #F9F9F9;
      --text-body: #555555;
      --text-muted: #888888;
      --border: #F0F0F0;
      --border-med: #EBEBEB;
      --orange-tint: #FFF5F0;
      --accent-purple: #7B5EF8;
      --accent-green: #10B981;
      --accent-blue: #0EA5E9;
      --accent-teal: #10B981;
      
      --font-display: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      /* Custom cursor handling */
      cursor: none !important;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: var(--font-body);
      color: var(--text-body);
      background-color: var(--bg-white);
      line-height: 1.9;
      overflow-x: hidden;
      font-size: 13px;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    ul {
      list-style: none;
    }

    /* Typography */
    h1, h2, h3, h4, .font-syne {
      font-family: var(--font-display);
      color: var(--dark);
      line-height: 1.1;
    }
    
    /* Dark context overrides */
    .p-card h3, .aeo-card h3, .contact-section h2, .contact-section h4 {
      color: #FFFFFF !important;
    }

    .subtitle {
      color: var(--text-muted);
      font-size: 10px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2.5px;
    }

    /* Buttons */
    .btnp {
      background: var(--primary);
      color: #fff;
      padding: 14px 28px;
      border-radius: 100px;
      font-weight: 600;
      font-size: 12px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: none;
      transition: background 0.3s, transform 0.3s ease;
      /* Magnetic effect applied via JS */
      transform-origin: center;
      position: relative;
    }
    .btnp:active { transform: scale(0.96) !important; }
    
    .btno {
      background: transparent;
      color: var(--dark);
      padding: 14px 28px;
      border-radius: 100px;
      font-weight: 600;
      font-size: 12px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      border: 1px solid var(--border-med);
      transition: all 0.3s;
    }
    .btno:hover {
      border-color: var(--primary);
      color: var(--primary);
    }
    .btno:active { transform: scale(0.96) !important; }

    /* Scroll Reveals */
    .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 0.65s ease, transform 0.65s ease;
    }
    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Section Padding */
    .section {
      padding: 88px 80px;
    }
    .container {
      max-width: 1100px;
      margin: 0 auto;
    }

    /* ==================================
       2. ANIMATIONS (Master List)
       ================================== */
    @keyframes floatR {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-16px); }
    }
    @keyframes glowPulse {
      0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
      50% { transform: translate(-50%, -50%) scale(1.09); opacity: 0.65; }
    }
    @keyframes spinC {
      from { transform: translate(-50%, -50%) rotate(0deg); }
      to { transform: translate(-50%, -50%) rotate(360deg); }
    }
    @keyframes spinCC {
      from { transform: translate(-50%, -50%) rotate(360deg); }
      to { transform: translate(-50%, -50%) rotate(0deg); }
    }
    @keyframes fbgF {
      0%, 100% { transform: translateY(0) rotate(-2deg); opacity: 0.055; }
      50% { transform: translateY(-24px) rotate(2deg); opacity: 0.09; }
    }
    @keyframes antigrav {
      0% { transform: translate(0, 0); }
      30% { transform: translateY(-20px) rotate(2deg); }
      60% { transform: translateY(-7px) rotate(-1deg); }
      100% { transform: translate(0, 0); }
    }
    @keyframes marq {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50% { transform: scale(0.85); opacity: 0.5; }
    }
    @keyframes robotPop {
      0% { transform: scale(1); }
      30% { transform: scale(1.13) rotate(-7deg); }
      70% { transform: scale(1.05) rotate(3deg); }
      100% { transform: scale(1); }
    }
    @keyframes blink {
      50% { opacity: 0; }
    }
    
    /* Robot Auto Wave Class */
    .robot.wave {
      animation: robotWave 0.8s ease;
    }
    @keyframes robotWave {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(-5deg); }
      50% { transform: rotate(5deg); }
      75% { transform: rotate(-3deg); }
    }

    /* ==================================
       3. CUSTOM CURSOR
       ================================== */
    #cur {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--primary);
      position: fixed;
      top: 0; left: 0;
      z-index: 9999;
      transform: translate(-50%, -50%);
      mix-blend-mode: multiply;
      pointer-events: none;
      transition: transform 0.08s ease;
    }
    #cur2 {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1.5px solid var(--primary);
      position: fixed;
      top: 0; left: 0;
      z-index: 9998;
      transform: translate(-50%, -50%);
      opacity: 0.45;
      pointer-events: none;
      transition: width 0.3s, height 0.3s, opacity 0.3s, background 0.3s;
    }
    #cur2.big {
      width: 70px;
      height: 70px;
      opacity: 0.18;
      background: rgba(255,107,44,0.1);
    }

    /* ==================================
       4. LOADING SCREEN
       ================================== */
    #loader {
      position: fixed;
      top: 0; left: 0; width: 100%; height: 100vh;
      background: var(--bg-white);
      z-index: 10000;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      transition: opacity 0.5s ease;
    }
    .loader-bot {
      font-size: 60px;
      animation: floatR 3.5s ease-in-out infinite;
      margin-bottom: 24px;
    }
    .loader-text {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 24px;
      color: var(--dark);
      margin-bottom: 8px;
    }
    .loader-sub {
      font-family: var(--font-body);
      color: var(--text-muted);
      font-size: 13px;
    }
    .cursor-blink { animation: blink 1s step-end infinite; }
    .loader-bar-container {
      position: absolute;
      bottom: 0; left: 0; width: 100%;
      height: 3px;
      background: var(--border-med);
    }
    .loader-bar {
      height: 100%;
      background: var(--primary);
      width: 0%;
      transition: width 2s linear;
    }

    /* ==================================
       5. FIXED ELEMENTS (Socials, Nav)
       ================================== */
    .fixed-socials {
      position: fixed;
      left: 24px;
      top: 50%;
      transform: translateY(-50%);
      display: flex;
      flex-direction: column;
      gap: 18px;
      z-index: 150;
    }
    .social-icon {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      background: var(--bg-white);
      border: 1.5px solid #e8e8e8;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06);
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .social-icon:hover {
      border-color: var(--primary);
      color: var(--primary);
      transform: scale(1.15);
      box-shadow: 0 4px 12px rgba(255,107,44,0.15);
    }

    .fixed-resume {
      position: fixed;
      bottom: 28px;
      right: 32px;
      z-index: 150;
      display: flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 10px;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: var(--text-muted);
      transition: color 0.3s;
    }
    .fixed-resume:hover { color: var(--primary); }
    .fixed-resume .icon-box {
      width: 22px; height: 22px;
      border: 1.5px solid currentColor;
      border-radius: 3px;
      display: flex; align-items: center; justify-content: center;
      font-size: 10px;
    }

    /* Navigation */
    nav {
      position: fixed;
      top: 0; left: 0; width: 100%;
      padding: 22px 80px;
      z-index: 2000;
      display: flex;
      justify-content: space-between;
      align-items: center;
      transition: all 0.3s ease;
      background: transparent;
      border-bottom: 1px solid transparent;
    }
    nav.sc {
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid var(--border-med);
      box-shadow: 0 4px 24px rgba(0,0,0,0.02);
      padding: 16px 80px;
    }
    
    .logo {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 22px;
      color: var(--dark);
    }
    .logo span { color: var(--primary); }
    
    .nav-email {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      font-size: 10.5px;
      color: #999;
      letter-spacing: 0.5px;
      transition: color 0.3s;
      z-index: 10;
    }
    .nav-email:hover { color: var(--primary); }
    
    .nav-links {
      display: flex;
      align-items: center;
      gap: 32px;
      margin-left: auto; /* Ensure it pushes right even if email is absolute */
    }
    .nav-links a:not(.btn-nav) {
      font-family: var(--font-body);
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 3px;
      color: #888;
      transition: color 0.3s;
    }
    .nav-links a:not(.btn-nav):hover, 
    .nav-links a:not(.btn-nav).active {
      color: var(--primary);
    }
    
    .btn-nav {
      background: var(--dark);
      color: #fff;
      padding: 10px 22px;
      border-radius: 100px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 1px;
      text-transform: uppercase;
      transition: all 0.3s;
      border: 1px solid var(--dark);
    }
    .btn-nav:hover {
      background: var(--primary);
      border-color: var(--primary);
    }

    .hamburger {
      display: none;
      background: none;
      border: none;
      font-size: 24px;
      color: var(--dark);
      cursor: pointer;
    }

    .mobile-menu {
      position: fixed;
      top: 68px; left: 0; width: 100%;
      background: var(--bg-white);
      border-bottom: 1px solid var(--border-med);
      overflow: hidden;
      max-height: 0;
      transition: max-height 0.4s ease;
      z-index: 199;
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .mobile-menu.open { max-height: 400px; }
    .mobile-menu ul { padding: 0 28px 20px 28px; }
    .mobile-menu ul li { border-bottom: 1px solid var(--border-med); }
    .mobile-menu ul li:last-child { border-bottom: none; border-top: 1px solid var(--border-med); margin-top: 8px; padding-top: 8px; }
    .mobile-menu ul li a {
      display: block;
      padding: 16px 0;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--dark);
    }
    .mobile-menu ul li a.mob-cta {
      background: var(--primary);
      color: #fff;
      text-align: center;
      border-radius: 8px;
      margin-top: 10px;
      border: none;
    }

    /* ==================================
       6. HERO SECTION
       ================================== */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 0 80px 56px;
      background: var(--bg-white);
      overflow: hidden;
    }

    /* Hero Center Background Elements */
    .hero-glow {
      position: absolute;
      top: 46%; left: 50%;
      transform: translate(-50%, -50%);
      width: 560px; height: 560px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,107,44,0.11) 0%, rgba(255,107,44,0.04) 50%, transparent 72%);
      animation: glowPulse 4s ease-in-out infinite;
      pointer-events: none;
    }
    .hero-glow2 {
      position: absolute;
      top: 46%; left: 50%;
      transform: translate(-50%, -50%);
      width: 800px; height: 800px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(255,107,44,0.04) 0%, transparent 65%);
      pointer-events: none;
    }

    /* Orbit Rings */
    .orbit-ring {
      position: absolute; top: 46%; left: 50%;
      border-radius: 50%;
      border: 1.5px dashed rgba(255,107,44,0.15);
      pointer-events: none;
    }
    .ring-1 { width: 360px; height: 360px; animation: spinC 24s linear infinite; }
    .ring-2 { width: 480px; height: 480px; animation: spinCC 36s linear infinite; border-color: rgba(255,107,44,0.1); }
    .ring-3 { width: 660px; height: 660px; animation: spinC 48s linear infinite; border-color: rgba(255,107,44,0.06); }

    /* Orbit Icons & Pills */
    .orbit-icon, .hero-pill {
      position: absolute;
      background: #fff;
      border: 1px solid var(--border-med);
      box-shadow: 0 8px 24px rgba(0,0,0,0.06);
      display: flex; align-items: center; justify-content: center;
      animation: floatR 4s ease-in-out infinite;
      z-index: 2;
    }
    .orbit-icon { width: 44px; height: 44px; border-radius: 12px; font-size: 20px; }
    .hero-pill { 
      padding: 8px 16px; border-radius: 100px; 
      font-size: 12px; font-weight: 600; color: var(--text-body);
      gap: 6px;
    }
    
    /* Center Robot */
    .robot-center {
      position: absolute;
      top: 46%; left: 50%;
      transform: translate(-50%, -50%);
      z-index: 3;
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .robot-emoji {
      font-size: clamp(130px, 17vw, 190px);
      filter: drop-shadow(0 28px 56px rgba(255,107,44,0.22));
      transition: filter 0.3s, transform 0.3s;
      /* Float wrapped inside center div to allow transform on hover/click */
      animation: floatR 3.5s ease-in-out infinite; 
    }
    .robot-emoji:hover {
      filter: drop-shadow(0 28px 60px rgba(255,107,44,0.4));
      cursor: none; /* custom cursor handles it */
    }
    .robot-emoji.pop {
      animation: robotPop 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    
    .speech-bubble {
      position: absolute;
      top: -40px;
      background: var(--dark);
      color: #fff;
      padding: 12px 20px;
      border-radius: 12px;
      font-weight: 500;
      font-size: 12px;
      min-width: 220px;
      text-align: center;
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.4s, transform 0.4s;
      pointer-events: none;
      box-shadow: 0 10px 24px rgba(0,0,0,0.2);
      z-index: 4;
    }
    .speech-bubble.show {
      opacity: 1;
      transform: translateY(0);
    }
    .speech-bubble::after {
      content: '';
      position: absolute;
      bottom: -6px; left: 50%;
      margin-left: -6px;
      border-width: 6px 6px 0;
      border-style: solid;
      border-color: var(--dark) transparent transparent transparent;
    }

    /* Flanking Cards */
    .hero-card {
      position: absolute;
      top: 42%;
      transform: translateY(-50%);
      background: #fff;
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.08);
      z-index: 5;
    }
    .card-left {
      left: calc(50% - 390px);
      padding: 20px 24px;
      border: 1px solid var(--border-med);
    }
    .card-right {
      right: calc(50% - 390px);
      background: var(--dark);
      color: #fff;
      padding: 24px;
      border: 1px solid rgba(255,107,44,0.15);
      box-shadow: 0 20px 60px rgba(0,0,0,0.14), 0 0 0 1px rgba(255,107,44,0.08);
      width: 240px;
    }
    .card-right .pulse-dot {
      width: 6px; height: 6px; background: var(--primary); border-radius: 50%;
      display: inline-block; margin-right: 6px;
      animation: pulse 2s infinite;
    }
    .bg-metric {
      position: absolute;
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 11.5px;
      letter-spacing: 2px;
      color: var(--primary);
      text-transform: uppercase;
      z-index: 1;
    }

    /* Hero Bottom Layout */
    .hero-bottom {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      width: 100%;
      z-index: 10;
      position: relative;
    }
    
    /* hero layout centers content now, removed .hero-left */
    .hero-name {
      font-family: var(--font-display);
      font-size: clamp(40px, 6.5vw, 82px);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -2px;
      text-transform: uppercase;
      color: var(--dark);
      margin-top: 16px;
      margin-bottom: 32px;
    }
    .hero-name div { margin-top: -4px; }
    
    .avail-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: var(--orange-tint);
      color: var(--primary);
      padding: 8px 16px;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 700;
      border: 1px solid rgba(255,107,44,0.2);
    }
    .avail-badge .dot {
      width: 8px; height: 8px;
      background: var(--primary);
      border-radius: 50%;
      animation: pulse 2s infinite;
    }
    
    .hero-buttons {
      display: flex; gap: 16px;
    }

    .hero-right {
      text-align: right;
      position: relative;
    }
    .hero-role {
      font-family: var(--font-display);
      font-size: clamp(40px, 6.5vw, 82px);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -2px;
      text-transform: uppercase;
      color: var(--dark);
      margin-bottom: 24px;
      position: relative;
    }
    .hero-role div { margin-top: -4px; }
    .hero-role .color-org { color: var(--primary); }
    
    .ghost-text {
      position: absolute;
      top: -30%; right: -5%;
      font-size: clamp(60px, 9vw, 110px);
      -webkit-text-stroke: 1.5px rgba(255,107,44,0.08); /* Rajesh style adapted */
      color: transparent;
      z-index: -1;
      pointer-events: none;
    }

    .hero-subtext {
      font-family: var(--font-body);
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.8;
      max-width: 320px;
      margin-left: auto;
    }

    /* ==================================
       7. RESPONSIVE BREAKPOINTS 1 (Header/Hero)
       ================================== */
    @media (max-width: 1140px) {
      .hero-card { display: none; }
      .nav-email { display: none; }
    }
    
    @media (max-width: 900px) {
      .nav-links { display: none; }
      .hamburger { display: block; }
      .fixed-socials { display: none; }
      .hero { padding: 0 40px 48px; min-height: 90vh; }
      .fixed-resume { right: 20px; bottom: 20px; }
    }

    @media (max-width: 768px) {
      .hero-bottom {
        flex-direction: column;
        align-items: flex-start;
        gap: 48px;
      }
      .hero-right {
        text-align: left;
      }
      .hero-subtext { margin-left: 0; }
      .ghost-text { top: -20%; right: auto; left: 0; }
      .robot-center { top: 38%; }
      .orbit-ring { top: 38%; }
      .hero-glow, .hero-glow2 { top: 38%; }
    }

    @media (max-width: 600px) {
      nav { padding: 16px 28px; }
      nav.sc { padding: 16px 28px; }
      .hero { padding: 0 28px 40px; }
      .orbit-icon { display: none; }
      .ring-3 { display: none; }
      .hero-buttons { flex-direction: column; width: 100%; }
      .hero-buttons .btnp, .hero-buttons .btno { width: 100%; justify-content: center; }
    }
    /* ==================================
       8. MARQUEE STRIP
       ================================== */
    .marquee-container {
      background: var(--primary);
      overflow: hidden;
      white-space: nowrap;
      padding: 11px 0;
      position: relative;
    }
    .marquee-content {
      display: inline-block;
      animation: marq 22s linear infinite;
    }
    .marquee-item {
      display: inline-block;
      color: #fff;
      font-size: 10px;
      font-family: var(--font-display);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 3px;
      padding-right: 24px;
    }

    /* ==================================
       9. STATS BAR
       ================================== */
    .stats-bar {
      background: var(--bg-light);
      border-top: 1px solid var(--border-med);
      border-bottom: 1px solid var(--border-med);
      padding: 48px 0;
    }
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      text-align: center;
    }
    .stat-item {
      border-right: 1px solid var(--border-med);
      padding: 0 16px;
    }
    .stat-item:last-child {
      border-right: none;
    }
    .stat-num {
      font-family: var(--font-display);
      font-weight: 800;
      font-size: 44px;
      color: var(--primary);
      line-height: 1.2;
    }
    .stat-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1.5px;
      color: var(--text-muted);
    }

    /* ==================================
       10. ABOUT SECTION
       ================================== */
    .about-section {
      background: var(--border-med);
      /* 1px gap trick: the grid gap reveals the background color as a border */
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
    }
    .about-left { background: var(--bg-white); padding: 88px 80px; }
    .about-right { background: var(--bg-light); padding: 88px 80px; }
    
    .sh { /* Section Heading */
      font-family: var(--font-display);
      font-size: clamp(32px, 5.5vw, 54px);
      font-weight: 800;
      letter-spacing: -2px;
      color: var(--dark);
      margin-top: 16px;
      margin-bottom: 24px;
    }
    .sh .color-org { color: var(--primary); }
    
    .nmq-callout {
      background: var(--orange-tint);
      border-left: 3px solid var(--primary);
      padding: 20px 24px;
      margin-top: 32px;
      border-radius: 0 8px 8px 0;
    }
    .nmq-label { font-size: 9px; font-weight: 700; color: var(--primary); text-transform: uppercase; letter-spacing: 2px; }
    .nmq-title { font-family: var(--font-display); font-weight: 700; font-size: 14px; color: var(--dark); margin: 4px 0; }
    .nmq-sub { font-size: 11px; color: var(--text-body); }
    
    .about-tags {
      display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap;
    }
    .atag {
      font-size: 11px; font-weight: 600; color: var(--text-body);
      padding: 6px 14px; border-radius: 100px;
      border: 1px solid var(--border-med);
    }

    .phil-nav {
      display: flex; gap: 8px; margin-top: 24px; margin-bottom: 32px;
    }
    .pbtn {
      width: 44px; height: 44px;
      border-radius: 50%;
      background: #fff;
      border: 1px solid var(--border-med);
      color: #888;
      font-weight: 700;
      font-size: 13px;
      display: flex; align-items: center; justify-content: center;
      transition: all 0.3s;
    }
    .pbtn:hover { border-color: var(--primary); color: var(--primary); }
    .pbtn.on { background: var(--primary); border-color: var(--primary); color: #fff; }
    
    .phil-slide {
      display: none;
      background: var(--orange-tint);
      border-left: 3px solid var(--primary);
      border-radius: 0 10px 10px 0;
      padding: 24px 32px;
      position: relative;
    }
    .phil-slide.on {
      display: block;
      animation: fadeUp 0.65s ease;
    }
    .phil-num {
      position: absolute; right: 24px; top: 16px;
      font-family: var(--font-display); font-weight: 800; font-size: 40px;
      color: var(--primary); opacity: 0.22; line-height: 1;
    }
    .phil-title { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: var(--dark); margin-bottom: 8px; }

    /* ==================================
       11. WHY YOU NEED ME
       ================================== */
    .wynm-section {
      background: var(--dark);
      padding: 88px 80px;
      position: relative;
      overflow: hidden;
      color: #fff;
    }
    .wynm-glow {
      position: absolute; top: -100px; right: -100px;
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(255,107,44,0.07) 0%, transparent 70%);
      pointer-events: none;
    }
    .wynm-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 56px;
      align-items: start;
      position: relative; z-index: 2;
    }
    
    .wynm-metrics {
      display: flex; gap: 32px; margin-top: 40px; margin-bottom: 40px;
    }
    .wm-stat { font-family: var(--font-display); font-weight: 800; font-size: 38px; color: var(--primary); line-height: 1.1; }
    .wm-label { font-size: 10px; color: #aaa; text-transform: uppercase; letter-spacing: 1.5px; font-weight: 700; margin-top: 4px; }
    
    .w-table {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px;
      padding: 24px;
    }
    .w-row {
      display: grid; grid-template-columns: 1fr 20px 1fr; gap: 16px;
      align-items: center;
      padding: 12px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .w-row:last-child { border-bottom: none; }
    .w-old { color: #888; text-decoration: line-through; font-size: 12px; }
    .w-arr { color: var(--primary); text-align: center; font-size: 14px; }
    .w-new { color: #e0e0e0; font-weight: 600; font-size: 12.5px; }

    .w-cards {
      display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
    }
    .w-card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 14px;
      padding: 24px;
      transition: all 0.3s;
    }
    .w-card:hover {
      background: rgba(255,107,44,0.08);
      border-color: rgba(255,107,44,0.25);
      transform: translateY(-3px);
    }
    .wc-icon { font-size: 24px; margin-bottom: 12px; }
    .wc-title { font-family: var(--font-display); font-weight: 700; font-size: 15px; color: #fff; margin-bottom: 8px; }
    .wc-desc { font-size: 12px; color: #aaa; line-height: 1.7; }

    .ai-banner {
      background: rgba(255,107,44,0.08);
      border: 1px solid rgba(255,107,44,0.18);
      border-radius: 14px;
      padding: 20px 24px;
      margin-top: 24px;
      display: flex; gap: 16px; align-items: center;
    }
    .ai-b-text h4 { font-family: var(--font-display); font-size: 14px; color: #fff; margin-bottom: 4px; }
    .ai-b-text p { font-size: 12px; color: #aaa; line-height: 1.6; }

    /* ==================================
       12. SKILLS ENGINE
       ================================== */
    .skills-section {
      background: var(--bg-light);
      padding: 88px 80px;
    }
    
    /* Layer 1: Antigravity Arena */
    .bubble-arena {
      height: 440px;
      background: linear-gradient(135deg, #fafafa 0%, #fff 100%);
      background-image: radial-gradient(circle, #e0e0e0 1px, transparent 1px);
      background-size: 28px 28px;
      border: 1px solid var(--border-med);
      border-radius: 20px;
      position: relative;
      margin-bottom: 24px;
    }
    .bub {
      position: absolute;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      font-size: 28px;
      transition: all 0.3s;
      z-index: 1;
    }
    .bub:hover {
      transform: scale(1.18) !important;
      border-color: var(--primary) !important;
      box-shadow: 0 16px 40px rgba(255,107,44,0.18);
      z-index: 10;
    }
    
    /* Bubble Tooltip */
    #b-tip {
      position: fixed;
      background: var(--dark);
      border-radius: 14px;
      padding: 16px 20px;
      max-width: 250px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      pointer-events: none;
      z-index: 10000;
      opacity: 0;
      transition: opacity 0.2s;
      color: #fff;
    }
    .b-th { font-family: var(--font-display); font-weight: 700; font-size: 14px; color: var(--primary); margin-bottom: 8px; }
    .b-tr { display: grid; grid-template-columns: 50px 1fr; gap: 8px; font-size: 11px; margin-bottom: 4px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 4px; }
    .b-tr:last-child { border-bottom: none; }
    .b-tl { color: #888; }
    .b-tv { color: #eee; font-weight: 500; }

    /* Layer 2: AI Stack */
    .ai-stack {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px;
      background: var(--border-med);
      margin-bottom: 24px; border-radius: 12px; overflow: hidden;
    }
    .ai-scard {
      background: #fff; padding: 32px;
      transition: background 0.3s;
    }
    .ai-scard:hover { background: var(--orange-tint); }
    .ai-sh { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--dark); margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .ai-stags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 16px; }
    .ai-stag { font-size: 10px; padding: 4px 10px; border-radius: 100px; background: #f5f5f5; color: #666; border: 1px solid #e8e8e8; }

    /* Layer 3: Tech Grid */
    .tech-grid {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px;
    }
    .t-card {
      background: #fff; border: 1px solid var(--border-med);
      padding: 24px 16px; text-align: center; border-radius: 12px;
      position: relative; overflow: hidden;
      transition: all 0.3s;
    }
    .t-card:hover {
      border-color: var(--primary);
      transform: translateY(-3px);
      box-shadow: 0 10px 28px rgba(255,107,44,0.09);
    }
    .t-card::after {
      content: ''; position: absolute; bottom: 0; left: 0;
      width: 100%; height: 3px; background: var(--primary);
      transform: scaleX(0); transition: transform 0.3s; transform-origin: left;
    }
    .t-card:hover::after { transform: scaleX(1); }
    
    /* ==================================
       13. EXPERIENCE TIMELINE
       ================================== */
    .exp-section {
      padding: 88px 80px;
    }
    .timeline {
      max-width: 800px;
      margin: 48px auto 0;
      position: relative;
    }
    .timeline::before {
      content: ''; position: absolute; left: 24px; top: 0; bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--primary), rgba(255,107,44,0));
    }
    
    .exp-item {
      position: relative; padding-left: 64px; margin-bottom: 24px;
    }
    .exp-dot {
      position: absolute; left: 17px; top: 22px;
      width: 16px; height: 16px; border-radius: 50%;
      background: #fff; border: 3px solid var(--primary);
      transition: all 0.3s; z-index: 2;
    }
    
    .exp-header {
      background: #fff; border: 1px solid var(--border-med);
      border-radius: 16px; padding: 20px 24px;
      display: flex; justify-content: space-between; align-items: center;
      transition: all 0.3s; position: relative;
    }
    .exp-header:hover { border-color: var(--primary); }
    .eh-role { font-family: var(--font-display); font-weight: 700; font-size: 18px; color: var(--dark); transition: color 0.3s; }
    .eh-comp { font-size: 13px; color: var(--text-muted); transition: color 0.3s; }
    .eh-icon { font-size: 20px; color: var(--primary); transition: transform 0.3s, color 0.3s; font-weight: 300; }
    
    .exp-body {
      max-height: 0; overflow: hidden;
      transition: max-height 0.5s cubic-bezier(0, 1, 0, 1);
    }
    .eb-inner {
      padding: 24px; background: var(--bg-light);
      border: 1px solid var(--border-med); border-top: none;
      border-radius: 0 0 16px 16px;
      margin-top: -8px; padding-top: 32px;
    }
    
    /* Open State */
    .exp-item.open .exp-dot { background: var(--primary); transform: scale(1.3); }
    .exp-item.open .exp-header { background: var(--primary); border-color: var(--primary); border-radius: 16px 16px 0 0; }
    .exp-item.open .eh-role, .exp-item.open .eh-comp, .exp-item.open .eh-icon { color: #fff; }
    .exp-item.open .eh-icon { transform: rotate(45deg); }
    .exp-item.open .exp-body { max-height: 600px; transition: max-height 0.8s ease-in-out; }
    
    .eb-meta { display: flex; gap: 12px; margin-bottom: 16px; align-items: center; }
    .eb-date { font-size: 12px; font-weight: 700; color: var(--primary); }
    .eb-badge { font-size: 9px; padding: 4px 10px; background: #e0e0e0; color: #555; border-radius: 100px; text-transform: uppercase; letter-spacing: 1px; font-weight: 700; }
    .eb-list { list-style: none; margin-top: 16px; }
    .eb-list li { position: relative; padding-left: 20px; margin-bottom: 12px; font-size: 12.5px; color: var(--text-body); }
    .eb-list li::before { content: 'ÃƒÂ¢Ã¢â‚¬Â Ã¢â‚¬â„¢'; position: absolute; left: 0; top: 0; color: var(--primary); font-weight: 700; }
    
    /* Responsive Breakpoints 2 (Content) */
    @media (max-width: 900px) {
      .about-section { display: flex; flex-direction: column; }
      .about-left, .about-right { padding: 64px 40px; }
      .wynm-grid { grid-template-columns: 1fr; }
      .skills-section, .exp-section { padding: 64px 40px; }
      .ai-stack { grid-template-columns: 1fr; }
      .tech-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .stats-grid { grid-template-columns: 1fr 1fr; grid-gap: 24px; }
      .stat-item { border-right: none; border-bottom: 1px solid var(--border-med); padding-bottom: 24px; }
      .stat-item:last-child { border-bottom: none; grid-column: span 2; }
      .w-cards { grid-template-columns: 1fr; }
    }
    @media (max-width: 600px) {
      .about-left, .about-right { padding: 48px 28px; }
      .skills-section, .exp-section { padding: 48px 28px; }
    }

    /* ==================================
       14. PROJECTS SECTION (Expandable Cards)
       ================================== */
    .projects-section {
      background: var(--bg-white);
      padding: 88px 80px;
      border-top: 1px solid var(--border-med);
    }
    .p-grid {
      display: grid; grid-template-columns: repeat(2, 1fr); gap: 1px; margin-top: 48px;
      background: #ebebeb; border: 1px solid #ebebeb; border-radius: 16px; overflow: hidden;
    }
    
    .p-card {
      background: var(--dark);
      border-radius: 0; /* Let grid container clip corners */
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
    .p-card:hover { transform: translateY(-3px); box-shadow: 0 16px 40px rgba(255,107,44,0.12); z-index: 2; position: relative; border-bottom-color: var(--primary) !important; }
    
    .pc-img {
      height: 240px; background: #eaeaea; position: relative; overflow: hidden;
    }
    .pc-img img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s; }
    .p-card:hover .pc-img img { transform: scale(1.05); }
    .pc-img-overlay { position: absolute; top:0; left:0; width:100%; height:100%; background: linear-gradient(to top, rgba(0,0,0,0.6), transparent); }
    
    .pc-metric-badge {
      position: absolute; bottom: 16px; left: 16px;
      background: var(--primary); color: #fff;
      padding: 6px 12px; border-radius: 100px;
      font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px;
    }
    
    .pc-content { padding: 24px; position: relative; }
    .pc-idx { font-family: var(--font-display); font-weight: 800; font-size: 40px; color: var(--border-med); position: absolute; right: 24px; top: 12px; line-height: 1; pointer-events: none; }
    .pc-title { font-family: var(--font-display); font-weight: 700; font-size: 20px; color: var(--dark); margin-bottom: 8px; width: 80%; }
    .pc-desc { font-size: 13px; color: var(--text-body); margin-bottom: 20px; line-height: 1.6; }
    
    .pc-tags { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 20px; }
    .pc-tag { font-size: 10px; font-weight: 600; color: var(--primary); background: var(--orange-tint); padding: 4px 10px; border-radius: 100px; }
    
    .pc-expand-btn {
      width: 100%; padding: 12px; background: #fff; border: 1px solid var(--border-med);
      border-radius: 8px; cursor: pointer; font-size: 12px; font-weight: 700; color: var(--dark);
      display: flex; justify-content: space-between; align-items: center; transition: all 0.3s;
    }
    .pc-expand-btn:hover { background: var(--orange-tint); border-color: var(--primary); color: var(--primary); }
    .pc-expand-btn::after { content: '+'; font-size: 16px; font-weight: 300; transition: transform 0.3s; }
    
    .pc-expanded {
      max-height: 0; overflow: hidden;
      transition: max-height 0.4s ease-out;
    }
    .p-card.open .pc-expanded { max-height: 800px; }
    .p-card.open .pc-expand-btn::after { transform: rotate(45deg); }
    .pc-expanded-inner {
      padding-top: 24px; border-top: 1px dashed var(--border-med); margin-top: 16px;
    }
    .pc-sec { margin-bottom: 16px; }
    .pc-sec h5 { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; }
    .pc-sec p, .pc-sec li { font-size: 12px; color: var(--text-body); line-height: 1.6; }
    .pc-sec ul { padding-left: 20px; }
    
    /* AEO SPECIAL CARD */
    .aeo-card {
      grid-column: 1 / -1; /* spans full width */
      background: var(--dark); color: #fff;
      display: grid; grid-template-columns: 1fr 1fr;
      align-items: center; gap: 0;
    }
    .aeo-card .pc-img { height: 100%; min-height: 380px; }
    .aeo-card .pc-content { padding: 48px; border-left: 1px solid rgba(255,255,255,0.1); }
    .aeo-card .pc-idx { color: rgba(255,255,255,0.05); font-size: 80px; top: 24px; }
    .aeo-card .pc-title { color: #fff; font-size: 28px; }
    .aeo-card .pc-desc { color: #aaa; font-size: 14px; }
    .aeo-card .pc-tag { background: rgba(255,107,44,0.15); border: 1px solid rgba(255,107,44,0.3); }
    .aeo-card .pc-sec h5 { color: #888; }
    .aeo-card .pc-sec p, .aeo-card .pc-sec li { color: #ccc; }
    .aeo-card .pc-expand-btn { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); color: #fff; }
    .aeo-card .pc-expand-btn:hover { background: var(--primary); border-color: var(--primary); }

    /* ==================================
       15. CERTIFICATIONS SECTION (Flip Cards)
       ================================== */
    .certs-section {
      background: var(--bg-light); border-top: 1px solid var(--border-med);
      padding: 88px 80px;
    }
    .c-grid {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px;
    }
    
    .flip-card {
      background-color: transparent;
      height: 220px;
      perspective: 1000px;
    }
    .flip-inner {
      position: relative; width: 100%; height: 100%;
      text-align: center;
      transition: transform 0.6s;
      transform-style: preserve-3d;
    }
    .flip-card:hover .flip-inner { transform: rotateY(180deg); }
    .fc-front, .fc-back {
      position: absolute; width: 100%; height: 100%;
      -webkit-backface-visibility: hidden; backface-visibility: hidden;
      border-radius: 14px; overflow: hidden;
    }
    
    /* Front: Title */
    .fc-front {
      background: #fff; border: 1px solid var(--border-med);
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      padding: 24px;
    }
    .fc-comp { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 12px; }
    .fc-title { font-family: var(--font-display); font-weight: 700; font-size: 16px; color: var(--dark); }
    .fc-icon { font-size: 32px; margin-bottom: 16px; }
    .fc-hint { position: absolute; bottom: 16px; font-size: 10px; color: var(--text-muted); display: flex; align-items: center; gap: 4px; }
    
    /* Back: Image Placeholder (will be replaced by actual images) */
    .fc-back {
      background: var(--dark); color: white;
      transform: rotateY(180deg);
      display: flex; align-items: center; justify-content: center;
      padding: 4px;
    }
    .fc-img-box {
      width: 100%; height: 100%; border-radius: 10px;
      background: #2a2a2a; display: flex; align-items: center; justify-content: center;
      flex-direction: column; gap: 8px; color: #555;
    }
    .fc-img-box img {
      width: 100%; height: 100%; object-fit: cover; border-radius: 10px;
      display: none; /* Hide until we have base64 */
    }
    
    /* ==================================
       16. CONTACT & FOOTER
       ================================== */
    .contact-section {
      background: var(--dark); color: #fff;
      padding: 120px 80px 48px;
    }
    .c-top {
      display: grid; grid-template-columns: 1fr 1fr; gap: 64px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 80px;
    }
    .c-top-left h2 { font-family: var(--font-display); font-size: min(6vw, 64px); font-weight: 800; line-height: 1; margin-bottom: 24px; letter-spacing: -2px; }
    .c-top-left p { color: #aaa; font-size: 16px; max-width: 400px; line-height: 1.6; margin-bottom: 40px; }
    
    /* Thank You Card */
    .ty-card {
      background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 20px; padding: 40px;
      position: relative; overflow: hidden;
    }
    .ty-card::before { content: ''; position: absolute; top:0; left:0; width:4px; height:100%; background: var(--primary); }
    .ty-icon { font-size: 40px; margin-bottom: 16px; }
    .ty-title { font-family: var(--font-display); font-size: 24px; font-weight: 700; margin-bottom: 12px; }
    .ty-desc { color: #ccc; font-size: 14px; line-height: 1.6; }
    .ty-signature { font-family: 'Times New Roman', Times, serif; font-style: italic; font-size: 24px; color: var(--primary); margin-top: 24px; }
    
    .footer-bot {
      display: flex; justify-content: space-between; align-items: center; padding-top: 48px;
    }
    .f-logo { font-family: var(--font-display); font-size: 18px; font-weight: 800; letter-spacing: -1px; }
    .f-copy { font-size: 12px; color: #888; }
    .f-links { display: flex; gap: 24px; }
    .f-links a { color: #ccc; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; transition: color 0.3s; }
    .f-links a:hover { color: var(--primary); }

    /* Responsive Breakpoints 3 (Projects/Contact) */
    @media (max-width: 1024px) {
      .p-grid { grid-template-columns: 1fr; }
      .aeo-card { grid-template-columns: 1fr; }
      .aeo-card .pc-img { height: 280px; min-height: auto; }
      .aeo-card .pc-content { border-left: none; border-top: 1px solid rgba(255,255,255,0.1); padding: 32px; }
      .c-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 900px) {
      .projects-section, .certs-section { padding: 64px 40px; }
      .contact-section { padding: 80px 40px 32px; }
      .c-top { grid-template-columns: 1fr; gap: 40px; padding-bottom: 48px; }
    }
    @media (max-width: 600px) {
      .projects-section, .certs-section { padding: 48px 28px; }
      .contact-section { padding: 64px 28px 24px; }
      .c-grid { grid-template-columns: 1fr; }
      .pc-content { padding: 20px; }
      .ty-card { padding: 24px; }
      .footer-bot { flex-direction: column; gap: 24px; align-items: flex-start; }
    }

  </style>
</head>
